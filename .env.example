# DeepSeek API ключ (обязательный для генерации README)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# GitHub токен (опционально, для пуша через HTTPS)
GITHUB_TOKEN=your_github_token_here

# Git identity (опционально, для коммитов)
GIT_USER_NAME=gh-manager
GIT_USER_EMAIL=gh-manager@local

# Порт веб-сервера (опционально)
PORT=3000

# Путь к конфигу (опционально)
CONFIG_PATH=./repos.config.json