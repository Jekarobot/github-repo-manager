{
  "name": "github-repo-manager",
  "version": "1.0.0",
  "description": "Управление GitHub репозиториями: автоматическая генерация README через DeepSeek API и обезличивание кода",
  "main": "dist/index.js",
  "bin": {
    "gh-manager": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "process": "tsx src/cli/index.ts process",
    "web": "tsx src/server/index.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "simple-git": "^3.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "tsx": "^4.6.0",
    "typescript": "^5.3.3"
  }
}